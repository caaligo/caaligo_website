---
const title = "Caaligo | Community";
---
<link rel="icon" type="image/png" href="/caaligo_icon.png">
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
</head>

<body>

  <aside class="sidebar">

    <div class="brand">
      <img src="/channellogo.jpg" alt="Caaligo Logo" class="channel-logo" />

      <h1>CAALIGO</h1>

      <p>
        Minecraft creator making videos,
        mods, and more.
      </p>
    </div>


    <div class="search">
      <input type="text" placeholder="Search..." />
    </div>


    <nav>
      <h3>Navigation</h3>

      <a href="/">Home</a>
      <a href="/content">Videos</a>
      <a href="/moe">Obsidian Edition</a>
      <a href="/blog">Blog</a>
      <a href="/community" class="active">Community</a>
      <a href="/about">About</a>

    </nav>


<nav>
  <h3>Socials</h3>
  <a href="https://www.youtube.com/@Caaligo/featured" target="_blank">YouTube</a>
  <a href="https://discord.gg/Hcg6yWWSjn" target="_blank">Discord</a>
  <a href="https://www.curseforge.com/members/caaligo/projects" target="_blank">CurseForge</a>
  <a href="https://www.instagram.com/caaligo_?igsh=cHJyMm4wMjV2eThq" target="_blank">Instagram</a>
  <a href="https://www.tiktok.com/@caaligo?_r=1&_t=ZT-980bISurc8j" target="_blank">TikTok</a>
  <a href="https://www.youtube.com/@LeoCaaligula" target="_blank">Caaligula</a>
</nav>

  </aside>



  <main class="main">

    <article class="paper">


      <div class="hero">

        <p class="label">
          COMMUNITY HUB
        </p>

        <h2>
          The Caaligo Community
        </h2>

        <p>
          Join the community surrounding Minecraft videos,
          ARGs, mods, and upcoming projects.
        </p>

      </div>


      <hr />



<section>

  <h3>
    Where to Find Caaligo
  </h3>


  <div class="card-grid">


    <div class="community-card">

      <img src="/youtube-icon.png" alt="YouTube">

      <h4>
        YouTube
      </h4>

      <p>
        Watch videos covering Minecraft history,
        forgotten versions, ARGs, mods, and experiments.
      </p>

      <a href="https://www.youtube.com/@Caaligo/featured" target="_blank">
        Visit Channel
      </a>

    </div>



    <div class="community-card">

      <img src="/discord-icon.png" alt="Discord">

      <h4>
        Discord
      </h4>

      <p>
        Join the community to discuss videos,
        theories, projects, and upcoming content.
      </p>

      <a href="https://discord.gg/Hcg6yWWSjn" target="_blank">
        Join Server
      </a>

    </div>



    <div class="community-card">

      <img src="/x-icon.png" alt="X">

      <h4>
        X
      </h4>

      <p>
        Follow updates, random thoughts,
        and occasional Caaligo nonsense.
      </p>

      <a href="https://x.com/caaligo_" target="_blank">
        Follow
      </a>

    </div>



    <div class="community-card">

      <img src="/instagram-icon.png" alt="Instagram">

      <h4>
        Instagram
      </h4>

      <p>
        See clips, short updates,
        and behind-the-scenes content.
      </p>

      <a href="https://www.instagram.com/caaligo_?igsh=cHJyMm4wMjV2eThq" target="_blank">
        View Instagram
      </a>

    </div>



    <div class="community-card">

      <img src="/tiktok-icon.png" alt="TikTok">

      <h4>
        TikTok
      </h4>

      <p>
        Watch short-form Minecraft content,
        clips, and discoveries.
      </p>

      <a href="https://www.tiktok.com/@caaligo?_r=1&_t=ZT-980bISurc8j" target="_blank">
        View TikTok
      </a>

    </div>



    <div class="community-card">

      <img src="/curseforge-icon.png" alt="CurseForge">

      <h4>
        CurseForge
      </h4>

      <p>
        Download Minecraft projects and follow
        development of Obsidian Edition and more.
      </p>

      <a href="https://www.curseforge.com/members/caaligo/projects" target="_blank">
        View Projects
      </a>

    </div>
    
        <div class="community-card">

      <img src="/caaligula-icon.jpg" alt="Caaligula">

      <h4>
        Caaligula (2nd Channel)
      </h4>

      <p>
        My channel for unrelated content.
      </p>

      <a href="https://www.youtube.com/@LeoCaaligula/featured" target="_blank">
        Visit Channel
      </a>

    </div>


  </div>

</section>

      <section>

        <h3>
          Community Projects
        </h3>


        <div class="project">

          <h4>
            Minecraft Obsidian Edition
          </h4>

          <p>
            A long-term Minecraft project focused on
            recreating the atmosphere of classic Minecraft
            while building something new.
          </p>


          <ul>

            <li>
              Custom gameplay experience
            </li>

            <li>
              Modern Minecraft foundation
            </li>

            <li>
              Active development
            </li>

          </ul>


          <a href="/moe">
            View Project
          </a>

        </div>



        <div class="project">

          <h4>
            Future ARG Projects
          </h4>

          <p>
            New mysteries, investigations, and interactive
            stories will appear here as they are released.
          </p>

        </div>


      </section>




      <section>

        <h3>
          Get Involved
        </h3>


        <div class="log">

          <h4>
            Suggest Ideas
          </h4>

          <p>
            Have a video idea, Minecraft topic, or theory?
            Share it with the community.
          </p>

        </div>



        <div class="log">

          <h4>
            Report Bugs
          </h4>

          <p>
            Found an issue with Obsidian Edition?
            Let development know.
          </p>

        </div>



        <div class="log">

          <h4>
            Share Your Creations
          </h4>

          <p>
            Share screenshots, builds, discoveries,
            and other Minecraft projects.
          </p>

        </div>


      </section>




      <section>

        <h3>
          Community Stats
        </h3>


        <div class="stats">

          <div>
            <strong>8,000+</strong>
            <span>YouTube Subscribers</span>
          </div>


          <div>
            <strong>Active</strong>
            <span>Discord Community</span>
          </div>


          <div>
            <strong>Growing</strong>
            <span>Minecraft Projects</span>
          </div>


        </div>


      </section>



    </article>


  </main>


</body>
</html>



<style>

:root {
  --accent: #58c7ff;
  --purple: #8c7cff;
  --paper: #ffffff;
}


body {

  margin:0;

  font-family:Arial, Helvetica, sans-serif;

  background-image:url("/space.jpg");

  background-size:cover;

  background-position:center;

  background-attachment:fixed;

}



.sidebar {

  position:fixed;

  width:280px;

  height:100vh;

  background:rgba(17,20,38,0.95);

  padding:35px;

  box-sizing:border-box;

  color:white;

}



.channel-logo {

  width:110px;

  height:110px;

  border-radius:50%;

  object-fit:cover;

  border:2px solid var(--accent);

}



.brand h1 {

  font-size:42px;

  letter-spacing:5px;

}



.brand p {

  color:#b8bfd8;

}



.search input {

  width:100%;

  padding:10px;

  margin:25px 0;

  background:#20243b;

  border:1px solid #333;

  color:white;

}



nav {

  margin-bottom:35px;

}


nav h3 {

  color:var(--accent);

  font-size:13px;

  text-transform:uppercase;

}



nav a {

  display:block;

  color:#cfd5ed;

  text-decoration:none;

  padding:8px 0;

}



nav a:hover,
nav a.active {

  color:white;

}



.main {

  margin-left:280px;

  padding:50px;

}



.paper {

  max-width:850px;

  margin:auto;

  background:white;

  padding:55px;

  box-shadow:0 20px 60px black;

}



.hero {

  text-align:center;

}



.label {

  color:#777;

  letter-spacing:3px;

}



hr {

  border:none;

  border-top:1px solid #ddd;

  margin:40px 0;

}



.card-grid {

  display:grid;

  grid-template-columns:repeat(2,1fr);

  gap:20px;

}



.community-card {

  background:#f2f4f8;

  padding:25px;

  text-align:center;

  border-left:5px solid var(--accent);

}



.community-card img {

  width:64px;

  height:64px;

}



.community-card a,
.project a {

  display:inline-block;

  margin-top:10px;

  background:#111426;

  color:white;

  padding:10px 18px;

  text-decoration:none;

}



.project {

  background:#f2f4f8;

  padding:25px;

  border-left:5px solid var(--purple);

  margin-bottom:20px;

}



.log {

  border-left:4px solid var(--accent);

  padding-left:20px;

  margin:25px 0;

}



.stats {

  display:grid;

  grid-template-columns:repeat(3,1fr);

  gap:15px;

}



.stats div {

  background:#f2f4f8;

  padding:20px;

  text-align:center;

}



.stats strong {

  display:block;

  font-size:24px;

}



.stats span {

  color:#666;

}



@media(max-width:900px) {

.sidebar {

position:relative;

width:100%;

height:auto;

}


.main {

margin-left:0;

padding:20px;

}


.card-grid,
.stats {

grid-template-columns:1fr;

}


.paper {

padding:30px;

}

}

</style>