      <p>
        Minecraft creator making videos,
        mods, and more.
      </p>
    </div>

    <div class="search">
      <input type="text" placeholder="Search..." />
    </div>

    <nav>
      <h3>Navigation</h3>
      <a href="/">Home</a>
      <a href="/content">Videos</a>
      <a href="/moe">Obsidian Edition</a>
      <a href="/blog">Blog</a>
      <a href="/community">Community</a>
      <a href="/about">About</a>
