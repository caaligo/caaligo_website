---
const title = "Caaligo | Obsidian Edition";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
</head>

<body>

  <aside class="sidebar">

    <div class="brand">
      <img src="/channellogo.jpg" alt="Caaligo Logo" class="channel-logo" />
      <h1>CAALIGO</h1>
      <p>
        Minecraft creator making videos,
        mods, and more.
      </p>
    </div>

    <div class="search">
      <input type="text" placeholder="Search..." />
    </div>

    <nav>
      <h3>Navigation</h3>
      <a href="/">Home</a>
      <a href="/content">Videos</a>
      <a href="/moe" class="active">Obsidian Edition</a>
      <a href="/blog">Blog</a>
      <a href="/community">Community</a>
      <a href="/about">About</a>
    </nav>

<nav>
  <h3>Socials</h3>
  <a href="https://www.youtube.com/@Caaligo/featured" target="_blank">YouTube</a>
  <a href="https://discord.gg/Hcg6yWWSjn" target="_blank">Discord</a>
  <a href="https://www.curseforge.com/members/caaligo/projects" target="_blank">CurseForge</a>
  <a href="https://www.instagram.com/caaligo_?igsh=cHJyMm4wMjV2eThq" target="_blank">Instagram</a>
  <a href="https://www.tiktok.com/@caaligo?_r=1&_t=ZT-980bISurc8j" target="_blank">TikTok</a>
  <a href="https://www.youtube.com/@LeoCaaligula" target="_blank">Caaligula</a>
</nav>

  </aside>

  <main class="main">

    <article class="paper">

      <div class="hero">
        <img src="/moelogo.png" alt="Minecraft Obsidian Edition Logo" class="moe-hero-logo" />
        <p class="label">MODPACK ARCHIVE</p>

        <h2>Obsidian Edition</h2>

        <p>
          An alternate edition of Minecraft following a different path of development.
        </p>
      </div>

      <hr />

      <section class="moe-about">
        <h3>About the Project</h3>
        
        <div class="about-text">
          <p>
            <strong>What if Minecraft took a different development route and was never sold to Microsoft?</strong>
          </p>
          <p>
            Minecraft: Obsidian Edition is an alternate vision of Minecraft, imagining a world where the game continued to evolve under a different design philosophy. Modern features are replaced with different versions of themselves, forgotten concepts are brought back to life and made new, and the game is reshaped to feel like a natural continuation of classic Minecraft rather than the one that we all love today.
          </p>
          <p>
            Discover new mechanics, the brave new world of the Skylands, restored legacy aesthetics, and an entirely different path through Minecraft's history.
          </p>
          <p class="dev-note">
            <em>This modpack is still in development! I hope to expand much more on it in the future! All content added to the game was created by me.</em>
          </p>
        </div>
      </section>

      <section class="moe-details">
        <h3>Project Details</h3>
        
        <div class="details-box">
          <div class="detail-item">
            <span class="detail-label">Latest Version</span>
            <span class="detail-value">1.20.1</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Mod Loader</span>
            <span class="detail-value">Forge</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Main File</span>
            <span class="detail-value">MOE 1.1.1.zip</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Downloads</span>
            <span class="detail-value">300+</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Categories</span>
            <span class="detail-value">Adventure, RPG, Exploration</span>
          </div>
        </div>
      </section>

<section>

  <div class="project">

    <h3>CurseForge Download</h3>

    <p>
      Download the latest version of Minecraft Obsidian Edition
      from CurseForge.
    </p>

    <a href="https://www.curseforge.com/minecraft/modpacks/obsidian-edition" target="_blank">
      Download on CurseForge
    </a>

  </div>

</section>

<section class="moe-gallery">

  <h3>Gallery</h3>

  <p class="section-desc">
    Screenshots from Obsidian Edition.
  </p>

  <div class="gallery-grid">

    <div class="gallery-slot">
      <img src="/screenshot1.png" alt="Screenshot 1">
    </div>

    <div class="gallery-slot">
      <img src="/screenshot2.png" alt="Screenshot 2">
    </div>

    <div class="gallery-slot">
      <img src="/screenshot3.png" alt="Screenshot 3">
    </div>

    <div class="gallery-slot">
      <img src="/screenshot4.png" alt="Screenshot 4">
    </div>

    <div class="gallery-slot">
      <img src="/screenshot5.png" alt="Screenshot 5">
    </div>

    <div class="gallery-slot">
      <img src="/screenshot6.png" alt="Screenshot 6">
    </div>

  </div>

</section>

</article>

</main>

</body>
</html>

<style>
:root {
  --accent: #58c7ff;
  --purple: #8c7cff;
  --paper: #ffffff;
  --dark-bg: #111426;
  --light-bg: #f2f4f8;
}

body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background-image: url("/space.jpg");
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
}

/* Sidebar */
.sidebar {
  position: fixed;
  width: 280px;
  height: 100vh;
  background: rgba(17,20,38,0.95);
  padding: 35px;
  box-sizing: border-box;
  color: white;
  overflow-y: auto;
}

/* Sidebar Channel Logo */
.channel-logo {
  width: 110px;
  height: 110px;
  border-radius: 50%;
  object-fit: cover;
  margin-bottom: 15px;
  border: 2px solid var(--accent);
  box-shadow: 0 0 15px rgba(88, 199, 255, 0.2);
}

.brand h1 {
  margin: 0;
  font-size: 42px;
  letter-spacing: 5px;
}

.brand p {
  color: #b8bfd8;
  line-height: 1.5;
}

.search input {
  width: 100%;
  padding: 10px;
  margin: 25px 0;
  box-sizing: border-box;
  background: #20243b;
  border: 1px solid #333;
  color: white;
}

nav {
  margin-bottom: 35px;
}

nav h3 {
  color: var(--accent);
  text-transform: uppercase;
  font-size: 13px;
  letter-spacing: 2px;
}

nav a {
  display: block;
  color: #cfd5ed;
  text-decoration: none;
  padding: 8px 0;
}

nav a:hover, nav a.active {
  color: white;
}

nav a.active {
  font-weight: bold;
  border-left: 2px solid var(--accent);
  padding-left: 10px;
  margin-left: -12px;
}

/* Main */
.main {
  margin-left: 280px;
  padding: 50px;
  min-height: 100vh;
}

.paper {
  max-width: 850px;
  margin: auto;
  background: var(--paper);
  padding: 55px;
  box-shadow: 0 20px 60px black;
}

.hero {
  text-align: center;
}

/* MOE Specific Hero Logo (Not circular, maintains proportions) */
.moe-hero-logo {
  max-width: 350px;
  height: auto;
  margin: 0 auto 20px auto;
  display: block;
}

.label {
  color: #777;
  letter-spacing: 3px;
}

.hero h2 {
  font-size: 42px;
  margin-top: 10px;
}

.hero p {
  color: #555;
  font-size: 18px;
}

hr {
  border: none;
  border-top: 1px solid #ddd;
  margin: 40px 0;
}

h3 {
  font-size: 24px;
}

/* About Text */
.about-text {
  background: var(--light-bg);
  padding: 25px;
  border-left: 5px solid var(--purple);
  line-height: 1.6;
}

.about-text p {
  margin-top: 0;
  margin-bottom: 15px;
}

.dev-note {
  color: #666;
  margin-bottom: 0 !important;
}

/* Details Box */
.moe-details {
  margin-top: 50px;
}

.details-box {
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
  background: var(--dark-bg);
  color: white;
  padding: 25px;
  border-left: 5px solid var(--accent);
}

.detail-item {
  flex: 1 1 calc(33.333% - 15px);
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 12px;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 5px;
}

.detail-value {
  font-size: 16px;
  font-weight: bold;
}

/* Gallery Section */
.moe-gallery {
  margin-top: 50px;
}

.section-desc {
  color: #666;
  margin-top: -15px;
  margin-bottom: 25px;
  font-size: 15px;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 15px;
}

.gallery-slot {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: var(--light-bg);
  border: 2px dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* Styling for when real images are inserted */
.gallery-slot img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  position: absolute;
  top: 0;
  left: 0;
}

.placeholder-img {
  color: #999;
  font-family: monospace;
  font-size: 14px;
}

@media(max-width:900px) {
  .sidebar {
    position: relative;
    width: 100%;
    height: auto;
  }
  .main {
    margin-left: 0;
    padding: 20px;
  }
  .paper {
    padding: 30px;
  }
  .detail-item {
    flex: 1 1 100%;
  }
}
</style>